{
  "name": "outside-ir35-jobs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@outside-ir35-jobs/web",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@outside-ir35-jobs/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "biome format --write .",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "cd apps/web && tsc --noEmit"
    ],
    "**/*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/prisma/schema.prisma": [
      "pnpm exec prisma format --schema"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.10.5",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "next": "16.2.10",
      "lightningcss": "1.30.1",
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "@shopify/react-native-skia",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
