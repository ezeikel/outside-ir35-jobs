# PostHog analytics (EU cloud). Same project token powers web + mobile so the
# two surfaces unify on one PostHog project. Get the token from PostHog →
# Project settings → Project API Key (starts with phc_).

# Client (public) — used by instrumentation-client.ts. In production the browser
# routes ingest through the /ingest reverse-proxy (see next.config.mjs rewrites);
# in dev it hits NEXT_PUBLIC_POSTHOG_HOST directly.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server (posthog-node) — used by utils/analytics-server.ts for the money events
# fired from webhooks/server actions. Same phc_ token; falls back to
# NEXT_PUBLIC_POSTHOG_KEY if unset.
POSTHOG_KEY=phc_your_project_key_here
