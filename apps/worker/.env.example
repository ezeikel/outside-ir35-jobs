# Outside IR35 Jobs aggregation worker — env. Copy to .env (gitignored).

# HTTP
PORT=3030
# Shared bearer secret the web cron sends; if unset, auth is skipped (dev only).
WORKER_SECRET=

# Database (same Neon DB as the web app). Use the unpooled URL for the worker.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# AI
ANTHROPIC_API_KEY=   # Claude Sonnet — classify/extract + Stagehand act/extract
OPENAI_API_KEY=      # text-embedding-3-small embeddings + gpt-image-2 blog featured-image fallback
# Pexels stock photos for blog featured images (https://www.pexels.com/api/).
# If unset, the blog image path skips Pexels and goes straight to gpt-image-2.
PEXELS_API_KEY=

# Scraping (Browserbase). If unset, falls back to local Playwright/Chromium.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Force local Playwright even when Browserbase keys are set:
# STAGEHAND_ENV=LOCAL

# Observability
SENTRY_DSN=
