{
  "name": "@outside-ir35-jobs/mobile",
  "main": "./index.js",
  "version": "0.1.0",
  "private": true,
  "expo": {
    "install": {
      "//": "Two pins expo-install/expo-doctor must not revert: (1) Expo SDK 57 still bundles @shopify/react-native-skia 2.6.2, whose podspec header glob breaks under use_frameworks!:static (forced by @react-native-firebase) → 'third_party/base64.h' not found. Fixed upstream in Skia 2.6.3 (PR #3853); we pin 2.6.9. (2) SDK 57 bundles @sentry/react-native ~7.11.0, but 7.x has the EAS build-time auth-token bug (source-map upload fails) → we pin ~8.12.0, the fleet-proven version.",
      "exclude": [
        "@shopify/react-native-skia",
        "@sentry/react-native"
      ]
    },
    "doctor": {
      "//": "RN Directory warnings, reviewed 2026-07: notifee is flagged unmaintained but is our FCM display layer (no drop-in replacement yet); the other two ship no directory metadata.",
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@notifee/react-native",
          "@swmansion/react-native-bottom-sheet",
          "react-native-enriched"
        ]
      }
    }
  },
  "scripts": {
    "clean": "git clean -xdf .expo node_modules",
    "start": "expo start",
    "dev": "expo start --ios",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-build-cache",
    "android": "expo run:android --no-build-cache",
    "build:ios": "pnpm prebuild:ios && pnpm ios",
    "build:android": "pnpm prebuild:android && pnpm android",
    "build": "expo export --platform ios --platform android",
    "eas:build:local": "eas build --profile development --local",
    "eas:build:local:ios": "eas build --platform ios --profile preview --local",
    "eas:build:local:android": "eas build --platform android --profile preview --local",
    "eas:build:development": "eas build --profile development",
    "eas:build:development:android": "eas build --platform android --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:ios:local": "eas build --profile preview --platform ios --local",
    "eas:build:preview:android:local": "eas build --profile preview --platform android --local",
    "eas:build:production": "eas build --profile production",
    "eas:release:ios": "eas build --profile production --platform ios --auto-submit",
    "eas:release:android": "eas build --profile production --platform android --auto-submit",
    "eas:submit:production": "eas submit --profile production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "maestro test .maestro",
    "lint": "biome lint .",
    "check-types": "tsc --noEmit",
    "env:pull": "eas env:pull --environment development",
    "doctor": "npx react-doctor@latest",
    "lint:fix": "biome lint --write ."
  },
  "dependencies": {
    "@expo-google-fonts/geist-mono": "^0.4.3",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/inter-tight": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/messaging": "^24.1.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~8.12.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.9",
    "@stripe/stripe-react-native": "0.64.0",
    "@swmansion/react-native-bottom-sheet": "0.10.1",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "expo": "~57.0.6",
    "expo-apple-authentication": "~57.0.1",
    "expo-application": "^57.0.1",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "~57.0.5",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.6",
    "expo-device": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.4",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.7",
    "expo-web-browser": "~57.0.1",
    "nativewind": "5.0.0-preview.2",
    "posthog-react-native": "^4.57.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "3.0.4",
    "react-native-enriched": "^0.8.1",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-graph": "1.2.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-pdf": "^7.0.4",
    "react-native-purchases": "^9.15.2",
    "react-native-reanimated": "~4.5.2",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.10.2",
    "sonner-native": "^0.25.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@evennit/notifee-expo-plugin": "^3.8.0",
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "^22.20.1",
    "@types/react": "19.2.14",
    "postcss": "^8.5.19",
    "tailwindcss": "4.1.18",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
