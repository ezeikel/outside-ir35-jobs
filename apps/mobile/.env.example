# Mobile (Expo) public env. EXPO_PUBLIC_* is inlined into the JS bundle — never
# put a secret here. Set per EAS build profile (development / preview / production).

# API + environment
EXPO_PUBLIC_API_URL=https://www.outsideir35jobs.com
EXPO_PUBLIC_ENVIRONMENT=development

# PostHog analytics (EU cloud). SAME phc_ project token as the web app
# (NEXT_PUBLIC_POSTHOG_KEY) so web + mobile events unify on one PostHog project;
# events are split by an `environment` / `platform` / `surface` prop, not by
# separate projects. Absent key ⇒ the PostHogProvider is not mounted and every
# analytics call no-ops.
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Auth (OAuth client ids — per app/variant)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=

# Payments (publishable / public halves only)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Maps + errors
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_SENTRY_DSN=
